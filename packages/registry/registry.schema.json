{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Virtue Composer component registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "title",
      "layer",
      "packageImport",
      "projectImport",
      "client",
      "props",
      "states",
      "accessibilityChecks",
      "replaces",
      "showcaseFixtures",
      "doctorRules",
      "stability",
      "since",
      "guidance",
      "contractVersion"
    ],
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "title": { "type": "string", "minLength": 1 },
      "layer": { "enum": ["structure", "navigation", "action", "field", "choice", "disclosure", "data", "content", "media", "feedback", "loading", "overlay"] },
      "packageImport": { "type": "string" },
      "projectImport": { "type": "string" },
      "client": { "type": "boolean" },
      "props": { "type": "array", "items": { "type": "string" } },
      "propContracts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "required": ["kind", "description"],
          "properties": {
            "kind": { "enum": ["array", "boolean", "descriptor-array", "enum", "function", "number", "react-node", "record", "string", "union"] },
            "itemType": { "type": "string" },
            "values": { "type": "array", "items": { "type": "string" } },
            "description": { "type": "string", "minLength": 1 }
          },
          "allOf": [
            {
              "if": { "properties": { "kind": { "enum": ["array", "descriptor-array"] } } },
              "then": { "required": ["itemType"] }
            },
            {
              "if": { "properties": { "kind": { "enum": ["enum", "union"] } } },
              "then": { "required": ["values"] }
            }
          ],
          "additionalProperties": false
        }
      },
      "states": { "type": "array", "items": { "type": "string" } },
      "accessibilityChecks": { "type": "array", "items": { "type": "string" } },
      "replaces": { "type": "array", "items": { "type": "string" } },
      "showcaseFixtures": { "type": "array", "items": { "type": "string" } },
      "doctorRules": { "type": "array", "items": { "type": "string" } },
      "selectionHints": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["rule", "from", "confidence", "message"],
          "properties": {
            "rule": { "enum": ["jsx-prop-equals", "jsx-prop-divisor", "jsx-ancestor"] },
            "from": { "type": "string", "minLength": 1 },
            "prop": { "type": "string", "minLength": 1 },
            "value": { "type": ["string", "number"] },
            "ancestor": { "type": "string", "minLength": 1 },
            "confidence": { "enum": ["high", "medium", "low"] },
            "message": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "stability": { "enum": ["stable", "beta", "experimental", "deprecated"] },
      "since": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
      "guidance": {
        "type": "object",
        "required": ["use", "avoid", "alternatives", "companions", "responsive"],
        "properties": {
          "use": { "type": "string", "minLength": 1 },
          "avoid": { "type": "string", "minLength": 1 },
          "alternatives": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }, "uniqueItems": true },
          "companions": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }, "uniqueItems": true },
          "responsive": { "type": "string", "minLength": 1 },
          "decision": {
            "type": "object",
            "required": ["nativeAlternative", "complexAlternative", "stateModel", "serverClientBoundary", "serialization", "focusOwnership", "failureModes", "compositions"],
            "properties": {
              "nativeAlternative": { "type": "string", "minLength": 1 },
              "complexAlternative": { "type": "string", "minLength": 1 },
              "stateModel": { "type": "string", "minLength": 1 },
              "serverClientBoundary": { "type": "string", "minLength": 1 },
              "serialization": { "type": "string", "minLength": 1 },
              "focusOwnership": { "type": "string", "minLength": 1 },
              "failureModes": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              },
              "compositions": {
                "type": "array",
                "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
                "uniqueItems": true
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "runtime": {
        "type": "object",
        "required": ["clientRequired", "engine", "measuredModuleBytes", "complexity", "effectCount", "listenerModel", "portal", "nativeAlternative", "scaleGuidance", "lazyLoad"],
        "properties": {
          "clientRequired": { "type": "boolean" },
          "engine": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "measuredModuleBytes": { "type": "integer", "minimum": 0 },
          "complexity": { "enum": ["low", "moderate", "high"] },
          "effectCount": { "type": "integer", "minimum": 0 },
          "listenerModel": { "type": "string", "minLength": 1 },
          "portal": { "type": "boolean" },
          "nativeAlternative": { "type": "string", "minLength": 1 },
          "scaleGuidance": { "type": "string", "minLength": 1 },
          "lazyLoad": { "enum": ["not-recommended", "optional", "recommended"] }
        },
        "additionalProperties": false
      },
      "security": {
        "type": "object",
        "required": ["acceptsHtml", "htmlPolicy", "dataSensitivity", "clientValidation", "serverValidation", "secretPolicy", "networkAuthority", "persistenceAuthority", "externalNavigation", "commerceAuthority", "warnings"],
        "properties": {
          "acceptsHtml": { "type": "boolean" },
          "htmlPolicy": { "type": "string", "minLength": 1 },
          "dataSensitivity": { "enum": ["none", "user-content", "personal", "files", "financial"] },
          "clientValidation": { "type": "string", "minLength": 1 },
          "serverValidation": { "type": "string", "minLength": 1 },
          "secretPolicy": { "type": "string", "minLength": 1 },
          "networkAuthority": { "enum": ["none", "navigation", "project-callback"] },
          "persistenceAuthority": { "enum": ["none", "project-callback"] },
          "externalNavigation": { "type": "string", "minLength": 1 },
          "commerceAuthority": { "type": "string", "minLength": 1 },
          "warnings": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "doctorHints": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["rule", "prop", "code", "message"],
              "properties": {
                "rule": { "const": "jsx-prop-absent" },
                "prop": { "type": "string", "minLength": 1 },
                "code": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
                "message": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "contractVersion": { "const": 1 }
    },
    "allOf": [
      {
        "if": {
          "anyOf": [
            { "required": ["runtime"] },
            { "required": ["security"] }
          ]
        },
        "then": {
          "properties": {
            "guidance": { "required": ["decision"] }
          }
        }
      }
    ],
    "additionalProperties": false
  }
}
