{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Virtue Composer page blueprint registry",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "title",
      "description",
      "selection",
      "sequence",
      "optional",
      "stability",
      "since",
      "contractVersion"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "selection": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "queries", "avoidWhen", "keywords"],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "queries": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "avoidWhen": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "keywords": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "sequence": {
        "type": "array",
        "minItems": 4,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      },
      "optional": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      },
      "stability": {
        "enum": ["experimental", "beta", "stable", "deprecated"]
      },
      "since": {
        "type": "string",
        "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
      },
      "contractVersion": {
        "const": 1
      }
    }
  }
}
